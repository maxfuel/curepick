# Required for production — all SEO URLs (canonical, hreflang, OG, sitemap) use this.
# Missing this makes the sitemap and SEO tags point to http://localhost:3000.
NEXT_PUBLIC_SITE_URL=https://your-domain.com

# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Required — admin server actions (hero image, site settings) and the hospital
# account management API use the service role key.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Email notifications (Resend) — inquiry submissions notify the admin.
RESEND_API_KEY=your-resend-api-key
ADMIN_EMAIL=admin@your-domain.com

# Review auto-translation (Google Cloud Translation API)
GOOGLE_TRANSLATE_API_KEY=your-google-translate-api-key

# Contact buttons (country code + number, no leading "+"). Buttons hide if unset.
NEXT_PUBLIC_WHATSAPP_NUMBER=821012345678
NEXT_PUBLIC_WECHAT_ID=your-wechat-id
